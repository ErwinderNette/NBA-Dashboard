# ---- Global image config ----
GHCR_OWNER=replace-me
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# ---- Traefik / TLS ----
ACME_EMAIL=devops@uppr.de

# ---- Postgres container vars ----
POSTGRES_DB=nba_dashboard_staging
POSTGRES_USER=nba_user_staging
POSTGRES_PASSWORD=replace-with-strong-password

# ---- Backend runtime vars ----
APP_ENV=staging
PORT=3001
DB_HOST=postgres-staging
DB_PORT=5432
DB_NAME=nba_dashboard_staging
DB_USER=nba_user_staging
DB_PASSWORD=replace-with-strong-password
DB_SSLMODE=require
DB_AUTO_MIGRATE=false

JWT_SECRET=replace-with-long-random-secret
FRONTEND_RESET_URL=https://staging.nba.uppr.de/reset-password
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_ADMIN_EMAILS=nachbuchungen@uppr.de
CORS_ALLOW_ORIGINS=https://staging.nba.uppr.de

NETWORK_API_BASE_URL=
NETWORK_API_TOKEN=
NETWORK_API_URL=

VALIDATION_DB_CACHE_ENABLED=true
CAMPAIGN_SYNC_SCHEDULER_ENABLED=true
CAMPAIGN_SYNC_POLL_SECONDS=60
CAMPAIGN_SYNC_MAX_CONCURRENCY=1
CAMPAIGN_SYNC_INITIAL_DELAY_SECONDS=10
CAMPAIGN_SYNC_OVERLAP_MINUTES=180

LOG_FORMAT=json
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none';
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_EXTENSIONS=.csv,.xlsx,.xls
UPLOAD_ALLOWED_MIME_TYPES=text/csv,text/plain,application/csv,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/octet-stream,application/zip

AVATAR_MAX_BYTES=5242880
AVATAR_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp
AVATAR_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

SEED_DEFAULT_USERS=false
SEED_SYNC_EXISTING_USERS=false
