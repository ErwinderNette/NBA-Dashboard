
# Kopiere diese Datei nach .env und fülle die Werte aus

# API Base URL für NBA-Plattform (Frontend)
VITE_API_BASE_URL=http://localhost:3001

# Backend: Basis-URL der Orders/Netzwerk-API (für „Aktualisieren“ mit Kampagne).
# Wenn gesetzt und campaignId beim Validate übergeben wird, lädt das Backend Orders von:
# NETWORK_API_BASE_URL + /6115e2ebc.../admin/5/get-orders.json
# NETWORK_API_URL = alternative: eine feste Voll-URL für alle Validierungen (ohne campaignId)
NETWORK_API_BASE_URL=
NETWORK_API_URL=
