APP_ENV=development
PORT=3001

DB_HOST=localhost
DB_USER=nba_user
DB_PASSWORD=change-me
DB_NAME=nba_dashboard
DB_PORT=5432
# In production use at least "require" or "verify-full"
DB_SSLMODE=disable
# Auto-migration should stay false in production (run schema changes separately)
DB_AUTO_MIGRATE=true

# REQUIRED in production
JWT_SECRET=replace-with-long-random-secret

# Comma-separated list of exact frontend origins
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:4173

# Observability and runtime protection
LOG_FORMAT=json
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'; form-action 'none';
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SECONDS=60

# Upload hardening
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_EXTENSIONS=.csv,.xlsx,.xls
UPLOAD_ALLOWED_MIME_TYPES=text/csv,text/plain,application/csv,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/octet-stream,application/zip

NETWORK_API_BASE_URL=
NETWORK_API_URL=

VALIDATION_DB_CACHE_ENABLED=true
CAMPAIGN_SYNC_SCHEDULER_ENABLED=true
CAMPAIGN_SYNC_POLL_SECONDS=60
CAMPAIGN_SYNC_MAX_CONCURRENCY=2
CAMPAIGN_SYNC_INITIAL_DELAY_SECONDS=10
CAMPAIGN_SYNC_OVERLAP_MINUTES=180

# Safety: disabled by default
SEED_DEFAULT_USERS=false
SEED_SYNC_EXISTING_USERS=false
